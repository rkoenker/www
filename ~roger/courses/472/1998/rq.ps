		1 1 Wid{
			Left PerByte eq{
				/CurByte curstr CurPos get def
				/MaskMove -8 Bits add def
				/CurPos CurPos 1 add def
			}if
			CurByte MaskMove bitshift MaskByte and
			dup 0 gt{
				Sc
