	/Times-Bold
	/Times-BoldItalic
	/Symbol
	/AvantGarde-Book
	/AvantGarde-BookOblique
	/AvantGarde-Demi
	/AvantGarde-DemiOblique
	/Bookman-Demi
	/Bookman-DemiItalic
	/Bookman-Light
	/Bookman-LightItalic
	/Helvetica-Narrow
	/Helvetica-Narrow-Bold
	/Helvetica-Narrow-BoldOblique
	/Helvetica-Narrow-Oblique
	/NewCenturySchlbk-Roman
	/NewCenturySchlbk-Bold
	/NewCenturySchlbk-Italic
	/NewCenturySchlbk-BoldItalic
	/Palatino-Roman
	/Palatino-Bold
	/Palatino-Italic
	/Palatino-BoldItalic
	/ZapfChancery-MediumItalic
	/ZapfDingbats
] def
/GColors [
	0
	0.6
	0.3
	0.9
	0.4
	0.7
	0.1
	0.5
	0.8
	0.2
] def
/BackCol -1 def
/IColors [
	0.933333
	0.866667
	0.8
	0.733333
	0.666667
	0.6
	0.533333
	0.466667
	0.4
	0.333333
	0.266667
	0.2
	0.133333
	0.0666667
	0
] def
/Colors GColors def
/IBu {Pch 0 8#267 put SetPchSize} def
/Bu {Pc} def

% all initialization action here
Iv I
currentdict /Ic known {Ic} if
currentdict /If known {If} if

%%EndSetup


