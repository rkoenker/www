else
  $echo 'x -' extracting 'rq.r' '(text)'
  sed 's/^X//' << 'SHAR_EOF' > 'rq.r' &&
#     this software has been submitted to statlib and may be freely
#     used and redistributed for non-commercial purposes.  no guarantees
#     are offered or implied.  comments, bug reports, etc are welcome
#     and should be sent to roger@ysidro.econ.uiuc.edu or to
#
#				roger koenker
#				department of economics
#				university of illinois
#				champaign, illinois, 61820
#
#
subroutine rq(m,nn,m5,n2,n4,a,b,t,toler,ift,x,e,s,wa,wb,nsol,ndsol,sol,dsol,lsol,h,qn,cutoff,ci,tnmat,big,lci1)
#
#     number of observations
#     number of parameters
#     m+5
#     n+2
#     n+4
#     a is the x matrix
#     b is the y vector
#     t, the desired quantile
#     toler, smallest detectable |x-y|/x machine precision to the 2/3
#     ift exit code:
#		0-ok
#		else dimensions inconsistent
#     x the parameter estimate betahat
#     e is the residual vector
#     s is an integer work array
#     wa is a double precision work array
#     wb is another double precision work array
#     nsol is an estimated (row) dimension of the primal solution array say 3*m; minimum value = 2
#     ndsol is an estimated (row) dimension of the dual solution array say 3*m; minimum value = 2
#     sol is the primal solution array
#     dsol is the dual solution arry
#     lsol is the actual dimension of the solution arrays
#     h is the matrix of basic observations indices
#     qn is the vector of residuals variances from the projection of each column of the x matrix on the remaining columns
#     cutoff, the critical point for N(0,1)
#     ci is the matrix of confident intervals
#     tnmat is the matrix of the JGPK rank test statistics
#     big, large positive finite floating-point number
#     utilization:  if you just want a solution at a single quantile you
#     needn't bother with sol, nsol, etc, if you want all the solutions
#     then set theta to something <0 and sol and dsol will return all the
#     estimated quantile solutions.
#     the algorithm  is a slightly modified version of algorithm as 229
#     described in koenker and d'orey, "computing regression quantiles,
#     applied statistics, pp. 383-393.
#
integer i,j,k,kl,kount,kr,l,lsol,m,m1,m2,m3,m4,m5,ift
integer n,n1,n2,nsol,ndsol,out,s(m),h(nn,nsol)
integer nn,n4,idxcf
logical stage,test,init,iend,lup
logical lci1,lci2,skip
double precision a1,aux,b1,big,d,dif,pivot,smax,t,t0,t1,tnt
double precision min,max,toler,zero,half,one,two
double precision b(m),sol(n2,nsol),a(m,nn),x(nn),wa(m5,n4),wb(m)
double precision sum,e(m),dsol(m,ndsol)
double precision qn(nn),cutoff,ci(4,nn),tnmat(4,nn),tnew,told,tn
data zero/0.00/
data half/0.50/
data one/1.00/
data two/2.00/
#
#  check dimension parameters
#
n=nn
ift = 0
wa(m+2,nn+1) = one
if (m5!=m+5)
X	ift = 3
if (n2!=n+2)
X	ift = 4
if (n4!=n+4)
X	ift = 5
if (m<=zero||n<=zero)
X	ift = 6
if (ift<=two) {
#
#  initialization
#
X	iend = .true.
X	lci2 = .false.
X	lup = .true.
X	skip = .false.
X	idxcf = 0
X	tnew = zero
X	tn = zero
X	m1 = m+1
X	n1 = n+1
X	n3 = n+3
X	m2 = m+2
X	m3 = m+3
X	m4 = m+4
X	do j = 1,n{
X		x(j) = zero
X		}
X	do i = 1,m
X		e(i) = zero
X	if (t<zero||t>one) {
X		t0 = one/float(m)-toler
X		t1 = one-t0
X		t = t0
X		iend = .false.
X		lci1 = .false.
X		}
X	repeat { #0
X		do i = 1,m {
X			k = 1
X			do j = 1,nn
X				if (k<=nn){
X					if(j==idxcf)
X						skip = .true.
X					else
X						skip = .false.
X					if(!skip){
X						wa(i,k) = a(i,j)
X						k = k+1
X						}
X					}	
X			wa(i,n4) = n+i
X			wa(i,n2) = b(i)
X			if (idxcf != 0)
X				wa(i,n3) = tnew*a(i,idxcf)
X			else
X				wa(i,n3) = zero
X			wa(i,n1) = wa(i,n2)-wa(i,n3)
X			if (wa(i,n1)<zero)
X				do j = 1,n4
X					wa(i,j) = -wa(i,j)
X			}
X		do j = 1,n {
X			wa(m4,j) = j
X			wa(m2,j) = zero
X			wa(m3,j) = zero
X			do i = 1,m {
X				aux = sign(one,wa(m4,j))*wa(i,j)
X				wa(m2,j) = wa(m2,j)+aux*(one-sign(one,wa(i,n4)))
X				wa(m3,j) = wa(m3,j)+aux*sign(one,wa(i,n4))
X				}
X			wa(m3,j) = two*wa(m3,j)
X			}
X		dif = zero
X		init = .false.
X		if(!lci2){
#compute the columns means
X			do k = 1,n {
X				wa(m5,k) = zero
X				do i = 1,m{
X					wa(m5,k) = wa(m5,k)+a(i,k)
X					}
X				wa(m5,k) = wa(m5,k)/float(m)
X				}
X			}
X		lsol = 1
X		kount = 0
X		repeat { #1
#
# compute new marginal costs
#
X			do j = 1,n{
X				wa(m1,j) = wa(m2,j)+wa(m3,j)*t
X				}
X			if (!init) {
#
# stage 1
#
# determine the vector to enter the basis
#
X				stage = .true.
X				kr = 1
X				kl = 1
X				go to 30
X				}
X			repeat { #2
#
# stage 2
#
X				stage = .false.
X				repeat { #3
#
# determine the vector to enter the basis
#
X					max = -big
X					do j = kr,n {
X						d = wa(m1,j)
X						if (d<zero) {
X							if (d>(-two))
X								next 1
X							d = -d-two
X							}
X						if (d>max) {
X							max = d
X							in = j
X							}
X						}
X					if (max<=toler)
X						break 2
X					if (wa(m1,in)<=zero) {
X						do i = 1,m4
X							wa(i,in) = -wa(i,in)
X						wa(m1,in) = wa(m1,in)-two
X						wa(m2,in) = wa(m2,in)-two
X						}
X					repeat { #4
#
# determine the vector to leave the basis
#
X						k = 0
X						do i = kl,m {
X							d = wa(i,in)
X							if (d>toler) {
X								k = k+1
X								wb(k) = wa(i,n1)/d
X								s(k) = i
X								test = .true.
X								}
X							}
X						repeat { #5
X							if (k<=0)
X								test = .false.
X							else {
X								min = big
X								do i = 1,k
X									if (wb(i)<min) {
X										j = i
X										min = wb(i)
X										out = s(i)
X										}
X								wb(j) = wb(k)
X								s(j) = s(k)
X								k = k-1
X								}
#
# check for linear dependence in stage 1
#
X							if (!test&&stage)
X								break 1
X							if (!test)
X								break 5
X							pivot = wa(out,in)
X							if (wa(m1,in)-pivot-pivot<=toler){
X								go to 10
X								}
X							do j = kr,n3 {
X								d = wa(out,j)
X								wa(m1,j) = wa(m1,j)-d-d
X								wa(m2,j) = wa(m2,j)-d-d
X								wa(out,j) = -d
X								}
X							wa(out,n4) = -wa(out,n4)
X							} #5
X						do i = 1,m4 {
X							d = wa(i,kr)
X							wa(i,kr) = wa(i,in)
X							wa(i,in) = d
X							}
X						kr = kr+1
X						go to 20
#
# pivot on wa(out,in)
#
X						10  do j = kr,n3
X							if (j!=in)
X								wa(out,j) = wa(out,j)/pivot
X						do i = 1,m3
X							if (i!=out) {
X								d = wa(i,in)
X								do j = kr,n3
X									if (j!=in)
X										wa(i,j) = wa(i,j)-d*wa(out,j)
X								}
X						do i = 1,m3
X							if (i!=out)
X								wa(i,in) = -wa(i,in)/pivot
X						wa(out,in) = one/pivot
X						d = wa(out,n4)
X						wa(out,n4) = wa(m4,in)
X						wa(m4,in) = d
X						kount = kount+1
X						if (!stage)
X							break 1
#
# interchange rows in stage 1
#
X						kl = kl+1
X						do j = kr,n4 {
X							d = wa(out,j)
X							wa(out,j) = wa(kount,j)
X							wa(kount,j) = d
X							}
X						20  if (kount+kr==n1)
X							break 2
X						30  max = -one
X						do j = kr,n
X							if (abs(wa(m4,j))<=n) {
X								d = abs(wa(m1,j))
X								if (d>max) {
X									max = d
X									in = j
X									}
X								}
X						if (wa(m1,in)<zero)
X							do i = 1,m4
X								wa(i,in) = -wa(i,in)
X						} #4
X					} #3
X				} #2
X			if (kr==1) {
X				do j = 1,n {
X					d = abs(wa(m1,j))
X					if (d<=toler||two-d<=toler){
X						ift = 1
X						wa(m2,nn+1) = zero
X						go to 80
X						}
X					}
X				}
X			80 kount = 0
X			sum = zero
X			if (!lci2){
X				do i = 1,kl-1 {
X					k = wa(i,n4)*sign(one,wa(i,n4))
X					x(k) = wa(i,n1)*sign(one,wa(i,n4))
X					}
X				}
X			do i = 1,n {
X				kd = abs(wa(m4,i))-n
X				dsol(kd,lsol) = one+wa(m1,i)/two
X				if (wa(m4,i)<zero)
X					dsol(kd,lsol) = one-dsol(kd,lsol)
X				if (!lci2){
X					sum = sum+x(i)*wa(m5,i)
X					sol(i+2,lsol) = x(i)
X					h(i,lsol) = kd
X					}
X				}
X			do i = kl,m {
X				kd = abs(wa(i,n4))-n
X				if (wa(i,n4)<zero)
X					dsol(kd,lsol) = zero
X				if (wa(i,n4)>zero)
X					dsol(kd,lsol) = one
X				}
X			if (!lci2){
X				sol(1,lsol) = smax
X				sol(2,lsol) = sum
X				do i=1,m
X					dsol(i,lsol+1) = dsol(i,lsol)
X				}
X			if (lci2){
# compute next theta
X				a1 = zero
X				do i = 1,m {
X					a1 = a1+a(i,idxcf)*(dsol(i,lsol)+t-one)
X					}
X				tn = a1/sqrt(qn(idxcf)*t*(one-t))
X				if (abs(tn)<cutoff){
X					if (lup)
X						smax = big
X					else
X						smax = -big
X					do i =1,kl-1 {
X						k = wa(i,n4)*sign(one,wa(i,n4))
X						sol(k,1) = wa(i,n2)*sign(one,wa(i,n4))
X						sol(k,2) = wa(i,n3)*sign(one,wa(i,n4))/tnew
X						}
X					do i = kl,m {
X						a1 = zero
X						b1 = zero
X						k = wa(i,n4)*sign(one,wa(i,n4))-n
X						l = 1
X						do j = 1,n{
X							if (j==idxcf)
X								l = l+1
X							a1 = a1 + a(k,l)*sol(j,1)
X							b1 = b1 + a(k,l)*sol(j,2)
X							l = l+1
X							}
X						tnt = (b(k)-a1)/(a(k,idxcf)-b1)
X						if (lup){
X							if (tnt>tnew)
X								if (tnt<smax){
X									smax = tnt
X									out = i
X									}
X							}
X						else {
X							if (tnt<tnew)
X								if (tnt>smax){
X									smax = tnt
X									out = i
X									}
X							}
X						}
X					if (lup){
X						told = tnew 
X						tnew = smax + toler
X						ci(3,idxcf) = told - toler
X						tnmat(3,idxcf) = tn
X						if (!(tnew < big-toler)){
X							ci(3,idxcf) = big
X							ci(4,idxcf) = big
X							tnmat(3,idxcf) = tn
X							tnmat(4,idxcf) = tn
X							lup = .false.
X							go to 70
X							}
X						}
X					else{
X						told = tnew 
X						tnew = smax - toler
X						ci(2,idxcf) = told + toler
X						tnmat(2,idxcf) = tn
X						if (!(tnew > -big+toler)){
X							ci(2,idxcf) = -big
X							ci(1,idxcf) = -big
X							tnmat(2,idxcf) = tn
X							tnmat(1,idxcf) = tn
X							lup = .true.
X							go to 60
X							}
X						}
#update the new marginal cost
X					do i = 1,m{
X						wa(i,n3) = wa(i,n3)/told*tnew
X						wa(i,n1) = wa(i,n2) - wa(i,n3)
X						}
X					do j = kr,n3{
X						d = wa(out,j)
X						wa(m1,j) = wa(m1,j) -d -d
X						wa(m2,j) = wa(m2,j) -d -d
X						wa(out,j) = -d
X						}
X					wa(out,n4) = -wa(out,n4)
X					init = .true.
X					}
X				else{
X					if (lup){
X						ci(4,idxcf) = tnew - toler
X						tnmat(4,idxcf) = tn
X						lup = .false.
X						go to 70
X						}
X					else{
X						ci(1,idxcf) = tnew + toler
X						tnmat(1,idxcf) = tn
X						lup = .true.
X						go to 60
X						}
X					}
X				}
X			if ((iend)&&(!lci2))
X				go to 40
X			if (!lci2){
X				init = .true.
X				lsol = lsol+1
X				do i = 1,m
X					s(i) = zero
X				do j = 1,n
X					x(j) = zero
#
#  compute next t
#
X				smax = two
X				do j = 1,n {
X					b1 = wa(m3,j)
X					a1 = (-two-wa(m2,j))/b1
X					b1 = -wa(m2,j)/b1
X					if (a1>=t)
X						if (a1<smax) {
X							smax = a1
X							dif = (b1-a1)/two
X							}
X					if (b1>t)
X						if (b1<smax) {
X							smax = b1
X							dif = (b1-a1)/two
X							}
X					}
X				tnt = smax+toler*(one+abs(dif))
X				if (tnt>=t1+toler)
X					iend = .true.
X				t = tnt
X				if (iend)
X					t = t1
X				}
X			} #1
X		wa(m2,nn+1) = two
X		ift = 2
X		go to 50
X		40  if (lsol>2) {
X			sol(1,1) = zero
X			sol(1,lsol) = one
X			do i = 1,m {
X				dsol(i,1) = one
X				dsol(i,lsol) = zero
X				dsol(i,lsol+1) = zero
X				}
X			}
X		l = kl-1
X		do i = 1,l
X			if (wa(i,n1)<zero)
X				do j = kr,n4
X					wa(i,j) = -wa(i,j)
X		50  sum = zero
X		if(!lci2){
X			do i = kl,m {
X				k = wa(i,n4)*sign(one,wa(i,n4))
X				d = wa(i,n1)*sign(one,wa(i,n4))
X				sum = sum+d*sign(one,d)*(half+sign(one,d)*(t-half))
X				k = k-n
X				e(k) = d
X				}
X			wa(m2,n2) = kount
X			wa(m1,n2) = n1-kr
X			wa(m1,n1) = sum
X			}
X		if (wa(m2,nn+1)==two)
X			break 1
X		if (!lci1)
X			break 1
X		if (!lci2){
X			lci2 = .true.
X			n = nn-1
X			n1 = n+1
X			n2 = n+2
X			n3 = n+3
X			n4 = n+4
X		60	idxcf = idxcf+1
X			if (idxcf>nn)
X				break 1
X		70	if (lup){
X				tnew = x(idxcf)+toler
X				told = tnew
X				ci(3,idxcf) = x(idxcf)
X				tnmat(3,idxcf) = zero
X				}
X			else{
X				tnew = x(idxcf)-toler
X				told = tnew
X				ci(2,idxcf) = x(idxcf)
X				tnmat(2,idxcf) = zero
X				}
X			}
X		} #0
X	# restore the original value of dual when ci is true
X	do i=1,m
X		dsol(i,lsol) = dsol(i,lsol+1)
X	}
return
end
X	
X	
X	
SHAR_EOF
  $shar_touch -am 1108114396 'rq.r' &&
  chmod 0644 'rq.r' ||
  $echo 'restore of' 'rq.r' 'failed'
  if ( md5sum --help 2>&1 | grep 'sage: md5sum \[' ) >/dev/null 2>&1 \
  && ( md5sum --version 2>&1 | grep -v 'textutils 1.12' ) >/dev/null; then
    md5sum -c << SHAR_EOF >/dev/null 2>&1 \
    || $echo 'rq.r:' 'MD5 check failed'
20b03efc166e6e062b91c3c76826dc36  rq.r
SHAR_EOF
  else
    shar_count="`LC_ALL= LC_CTYPE= LANG= wc -c < 'rq.r'`"
    test 11442 -eq "$shar_count" ||
    $echo 'rq.r:' 'original size' '11442,' 'current size' "$shar_count!"
  fi
fi
# ============= rq.s ==============
if test -f 'rq.s' && test "$first_param" != -c; then
  $echo 'x -' SKIPPING 'rq.s' '(file already exists)'
else
  $echo 'x -' extracting 'rq.s' '(text)'
  sed 's/^X//' << 'SHAR_EOF' > 'rq.s' &&
"qrq"<-
function(s, a)
{
#computes linearized quantiles from rq data structure
#s is the rq structure e.g. rq(x,y)
#a is a vector of quantiles required
X	if(min(a) < 0 || max(a) > 1) stop("alphas out of range [0,1]")
X	r <- s$sol[1,  ]
X	q <- s$sol[2,  ]
X	q <- c(q[1], q)
X	J <- length(r)
X	r <- c(0, (r[1:J - 1] + r[2:J])/2, 1)
X	u <- rep(0, length(a))
X	for(k in 1:length(a)) {
X		i <- sum(r < a[k])
X		w <- (a[k] - r[i])/(r[i + 1] - r[i])
X		u[k] <- w * q[i + 1] + (1 - w) * q[i]
X	}
X	u
}
"rq"<-
function(x, y, tau = -1, alpha = 0.10000000000000001, dual = F, int = T, 
X	ci = T, method="score", interpolate = T, tcrit = T, hs=T)
{
#function to compute regression quantiles
X	if(!is.loaded(symbol.For("rq")))
X		dyn.load("rq_l.o")
X	if((tau<=0 || tau>=1) && ci){
X		ci <- F
X		}
X	if(ci && method != "score" && method != "sparsity"){
X		stop("method has to be ``score'' or ``sparsity''")
X		}
X	if(missing(x)) {
X		x <- matrix(rep(1, length(y)), length(y))
X		int <- FALSE
X		if(ci && method=="score"){
X			warning("method has been set to ``sparsity'' to compute confidence interval for sample quantile")
X			method <- "sparsity"
X			}
X		}
X	else{
X		x <- as.matrix(x)
X		if(int) 
X			x <- cbind(1, x)
X		else if(ncol(x)==1 && ci && method=="score"){
X			warning("method has been set to ``sparsity'' to compute confidence interval when x has only one column with no intercept")
X			method <- "sparsity"
X			}
X		}
X	tol <- .Machine$double.eps^(2/3)
X	big <- .Machine$double.xmax
X	x <- as.matrix(x)
X	p <- ncol(x)
X	n <- nrow(x)
X	if(n != length(y))
X		stop("x and y don't match n")
X	nsol <- 2
X	ndsol <- 2
X	if(tcrit)
X		cutoff <- qt(1 - alpha/2, n - p)
X        else 
X		cutoff <- qnorm(1 - alpha/2)
X	if(ci){
X		xxinv <- solve(crossprod(x))
X		qn <- 1/diag(xxinv)
X		}
X	else
X		qn <- rep(0,p)
X	t.orig <- tau
X	if(tau < 0 || tau > 1 || (ci && method=="sparsity")) {
X		nsol <- 3 * n
X		lci1 <- F
X		ndsol <- nsol
X		tau <- -1
X		}
X	else {
X		if(!ci)
X			lci1 <- F
X		else lci1 <- T
X		}
X	z <- .Fortran("rq",
X		as.integer(n),
X		as.integer(p),
X		as.integer(n + 5),
X		as.integer(p + 2),
X		as.integer(p + 4),
X		as.double(x),
X		as.double(y),
X		as.double(tau),
X		as.double(tol),
X		flag = as.integer(1),
X		coef = double(p),
X		resid = double(n),
X		integer(n),
X		double((n + 5) * (p + 4)),
X		double(n),
X		as.integer(nsol),
X		as.integer(ndsol),
X		sol = double((p + 2) * nsol),
X		dsol = double(n * ndsol),
X		lsol = as.integer(0),
X		h = integer(p * nsol),
X		qn = as.double(qn),
X		cutoff = as.double(cutoff),
X		ci = double(4 * p),
X		tnmat = double(4 * p),
X		as.double(big),
X		as.logical(lci1))
X	tau <- t.orig
X	if(z$flag != 0)
X		warning(switch(z$flag,"Solution may be nonunique",
X		"Premature end - possible conditioning problem in x."))
X	if(tau < 0 || tau > 1) {
X		z$sol <- matrix(z$sol, p + 2, z$lsol)
X		if(length(dimnames(x)[[2]]) == 0) {
X			if(int)
X				xn <- c("Intercept", paste("X", 1:(p - 1), sep
X				   = ""))
X			else xn <- paste("X", 1:p, sep = "")
X			}
X		else {
X			xn <- dimnames(x)[[2]]
X			if(int)
X				xn[1] <- "Intercept"
X			}
X		dimnames(z$sol) <- list(c("Probility", "Quantile", xn), NULL)
X		z$h <- matrix(z$h, p, z$lsol)
X		if(dual) {
X			z$dsol <- matrix(z$dsol, n, z$lsol)
X			z[c("sol", "dsol", "h")]
X			}
X		else z[c("sol", "h")]
X		}
X	else {
X		if(ci){
X			if(method=="score") {
X				if(interpolate){
X					Tn <- matrix(z$tnmat, nrow = 4)
X					Tci <- matrix(z$ci, nrow = 4)
X					Tci[3,] <- Tci[3,] + (cutoff - abs(Tn[3,
X					]))/abs(Tn[4,] - Tn[3,]) * abs(Tci[4,] - 					Tci[3,])
X					Tci[2,] <- Tci[2,] - (cutoff - abs(Tn[2,
X					]))/abs(Tn[1,] - Tn[2,]) * abs(Tci[1,] - 					Tci[2,])
X					Tci[2,  ][is.na(Tci[2,  ])] <-  - big
X					Tci[3,  ][is.na(Tci[3,  ])] <- big
X					dimnames(Tci)<-list(c("Lower Bound",
X					"Lower Bound","Upper Bound",
X					"Upper Bound"),NULL)
X					if(dual)
X						return(coef = z$coef, resid = 
X						z$resid, dual = z$dsol[1:n], 
X						h = z$h[1:p], ci = Tci[2:3,  ])
X					else 
X						return(coef = z$coef, resid = 
X						z$resid, h = z$h[1:p], ci = 
X						Tci[2:3,  ])
X					}
X				else {
X					Tci <- matrix(z$ci,nrow=4)
X					dimnames(Tci)<-list(c("Lower Bound",
X					"Lower Bound","Upper Bound",
X					"Upper Bound"),NULL)
X					if(dual)
X						return(coef = z$coef, resid = 
X						z$resid, dual = z$dsol[1:n], 
X						h = z$h[1:p], ci = Tci, Tn = 
X						matrix(z$tnmat, nrow = 4))
X					else return(coef = z$coef, resid = 
X						z$resid, h = z$h[1:p], ci = 
X						Tci, Tn = matrix(z$tnmat, 
X						nrow = 4))
X					}
X				}
X			else if(method=="sparsity"){
X				z$sol<-matrix(z$sol,p+2,z$lsol)
X				z$dsol<-matrix(z$dsol,n,z$lsol)
X				z$h <- matrix(z$h,p,z$lsol)
X				se<-diag(rq.omega(z,tau,hs=hs,alpha=alpha)*xxinv)^.5
X				Tci<-matrix(0,2,p)
X				dimnames(Tci)<-list(c("Lower Bound",
X				"Upper Bound"),NULL)
X				isol <- sum(z$sol[1,]<=tau)
X				Tcoef<-z$sol[3:(p+2),isol]
X				Tci[1,]<-Tcoef-cutoff*se
X				Tci[2,]<-Tcoef+cutoff*se
X				if(dual)
X					return(coef=Tcoef, resid=as.single(
X					y-x%*%Tcoef), dual = z$dsol[,isol], 
X					h = z$h[,isol], ci=Tci)
X				else 
X					return(coef=Tcoef, resid=as.single(
X					y-x%*%Tcoef), h = z$h[,isol], ci=Tci)
X				}
X			}
X		else {
X			if(dual)
X				return(coef = z$coef, resid = z$resid, dual = 
X				z$dsol[1:n], h = z$h[1:p])
X			else 
X				return(coef = z$coef, resid = z$resid, h = 
X				z$h[1:p])
X			}
X		}
}
"rq.omega"<-
function(z, tau = 0.5, hs = F, alpha = alpha)
{
#computes omega^2=tau(1-tau)/f^2(xi_a) for se of rq's
#uses linearized eqf from the full rq-process see function qrq()
#bandwidth is either Bofinger (hs=F) or Hall-Sheather (hs=T)
#z is the rq structure 
X	dn <- dn(tau, nrow(z$dsol), hs = hs, alpha = alpha)
X	low <- tau-dn
X	up <- tau+dn
X	if(low<0 || up>1){
X		warning("bandwidth is truncated to [0,1]")
X		low <- z$sol[1,2]
X		up <- z$sol[1,ncol(z$sol)-1]
X		}
X	q <- qrq(z, c(low, up))
X	shat <- diff(q)/(2 * dn)
X	tau * (1 - tau) * shat^2
}
"dn"<-
function(p, n, hs = F, alpha)
{
X	PI <- 3.1415899999999999
X	x0 <- qnorm(p)
X	f0 <- (1/sqrt(2 * PI)) * exp(.Uminus((x0^2/2)))
X	if(hs == T)
X		n^(-1/3) * qnorm(1 - alpha/2)^(2/3) * ((1.5 * f0^2
X			)/(2 * x0^2 + 1))^(1/3)
X	else n^-0.20000000000000001 * ((4.5 * f0^4)/(2 * x0^2 + 1)^2)^
X			0.20000000000000001
}
"trq"<-
function(x, y, a1 = 0.1, a2, z, int = T, method = "primal", tol = 0.0001)
{
#compute trimmed regression quantiles
#z is the rq strcture 
X	if(missing(a2)) a2 <- a1
X	if(a1 < 0 || a2 < 0)
X		stop("trimming proportion negative.")
X	if(a1 + a2 - 1 > tol)
X		stop("trimming proportion greater than 1.")
X	if(method!="primal" && method!="dual")
X		stop("invalid method: should be 'primal' or 'dual'.")
X	x <- as.matrix(x)
X	if(missing(z))
X		z <- rq(x, y,  , int )
X	p <- z$sol[1,  ]
X	q <- matrix(z$sol[ - c(1, 2),  ], nrow(z$sol) - 2, ncol(z$sol))
X	n <- nrow(z$dsol)
X	s <- NULL
X	if(length(dimnames(x)[[2]]) == 0)
X		dimnames(x) <- list(NULL, paste("X", 1:(nrow(q) - 1), sep = "")
X			)
X	if(int) {
X		x <- cbind(1, x)
X		dimnames(x)[[2]][1] <- "Intercept"
X	}
X	xbar <- apply(x, 2, "mean")
X	xxinv <- solve(t(x) %*% x)
X	if(abs(a1 + a2 - 1) <= tol) {
#single quantile case
X		i <- sum(p < a1)
X		s$coef <- q[, i]
X		names(s$coef) <- dimnames(x)[[2]]
X		s$resid <- y - x %*% s$coef
X		PI <- 3.14159
X		x0 <- qnorm(a1)
X		d0 <- (1/sqrt(2 * PI)) * exp( - (x0^2/2))
X		d0 <- ((4.5 * d0^4)/(2 * x0^2 + 1)^2)^0.2
X		d <- d0 * (length(s$resid) - length(s$coef))^(-0.2)
X		if(d > min(a1, 1 - a1))
X			d <- min(a1, 1 - a1)
X		s$d <- d
X		i <- sum(p < a1 + d)
X		j <- sum(p < a1 - d)
X		shat <- as.numeric(xbar %*% t(q[, i] - q[, j]))/(2 * d)
X		s$int <- int
X		s$v <- a1 * (1 - a1) * shat^2
X		s$cov <- s$v * xxinv
X	}
X	else {
#real trimming
X		p1 <- p[-1]
X		f <- 1/(1 - a1 - a2)
X		d <- pmax((pmin(p1, 1 - a2) - c(a1, pmax(p1[ - length(p1)],
X			a1))), 0)
X		if(method == "primal") {
X			s$coef <- q[, 1:length(p1)] %*% t(d) * f
X			s$resid <- y - x %*% s$coef
X			s$int <- int
X		}
X		else {
#Jureckova-Gutenbrunner trimmed least squares
X			i <- max(1, sum(p < a1))
X			g <- (z$dsol[, i + 1] - z$dsol[, i])/(p[i + 1] - p[
X				i])
X			wa <- z$dsol[, i] + (a1 - p[i]) * g
X			j <- sum(p < 1 - a2)
X			g <- (z$dsol[, j + 1] - z$dsol[, j])/(p[j + 1] - p[
X				j])
X			wb <- z$dsol[, j] + (1 - a2 - p[j]) * g
X			wt <- wa - wb
X			if(min(wt) < 0)
X				warning("some weights negative!")
X			s <- lsfit(x, y, abs(wt), int = F)
X		}
#now compute covariance matrix estimate
X		mu <- xbar %*% s$coef
X		v <- d %*% t((z$sol[2, 1:length(d)] - mu)^2)
X		k <- qrq(z, c(a1, a2)) - mu
X		v <- v + a1 * k[1]^2 + a2 * k[2]^2 + (a1 * k[1] + a2 * k[2])^2
X		names(s$coef) <- dimnames(x)[[2]]
X		s$v <- as.vector(f^2 * v)
X		s$cov <- s$v * xxinv
X	}
X	s
}
"trq.print"<-
function(trq.out, digits = 4)
{
X	n <- length(trq.out$resid)
X	p <- length(trq.out$coef)
X	options(warn = -1)
X	if(trq.out$int) {
X		df.num <- p - 1
X		fstat <- c(trq.out$coef[-1] %*% solve(trq.out$cov[-1, -1]) %*%
X			t(trq.out$coef[-1]))/df.num
X	}
X	else {
X		df.num <- p
X		fstat <- trq.out$coef %*% solve(trq.out$cov) %*% t(trq.out$coef
X			)/df.num
X	}
X	pvalue <- 1 - pf(fstat, df.num, (n - p))
X	cat(paste("Winsorized Standard Error of Regression= ", format(round(
X		sqrt(trq.out$v), digits)), "\n", "N = ", format(n), 
X		",  F-statistic = ", format(round(fstat, digits)), " on ",
X		format(df.num), " and ", format((n - p)), " df, ", "p-value = ",
X		format(round(pvalue, digits)), "\n\n", sep = ""))
X	regstat <- c(sqrt(trq.out$v), n, fstat, df.num, (n - p), pvalue)
X	names(regstat) <- c("rse", "n", "F.stat", "df.num", "df.den", "p.value"
X		)
X	err <- sqrt(diag(trq.out$cov))
X	tstat <- c(trq.out$coef/err)
X	tabcoef <- cbind(trq.out$coef, err, tstat, 2 * (1 - pt(abs(tstat),
X		n - p)))
X	dimnames(tabcoef) <- list(names(trq.out$coef), c("coef", "std.err",
X		"t.stat", "p.value"))
X	options(warn = 0)
X	print(round(tabcoef, digits))
X	invisible(list(summary = regstat, coef.table = tabcoef))
}
"ranks"<-
function(v, score = "wilcoxon")
{
X	A2 <- 1
X	if(score == "wilcoxon") {
X		J <- ncol(v$sol)
X		dt <- v$sol[1, 2:J] - v$sol[1, 1:(J - 1)]
X		ranks <- as.vector((0.5 * (v$dsol[, 2:J] + v$dsol[, 1:(J - 1)]) %*%
X			dt) - 0.5)
X		return(ranks, A2 = 1/12)
X	}
X	else if(score == "normal") {
X		J <- ncol(v$sol)
X		dt <- v$sol[1, 2:J] - v$sol[1, 1:(J - 1)]
X		dphi <- c(0, phi(qnorm(v$sol[1, 2:(J - 1)])), 0)
X		dphi <- diff(dphi)
X		ranks <- as.vector((((v$dsol[, 2:J] - v$dsol[, 1:(J - 1)]))) %*% (
X			dphi/dt))
X		return(ranks, A2)
X	}
X	else if(score == "sign") {
X		j.5 <- sum(v$sol[1,  ] < 0.5)
X		w <- (0.5 - v$sol[1, j.5])/(v$sol[1, j.5 + 1] - v$sol[1, j.5])
X		r <- w * v$dsol[, j.5 + 1] + (1 - w) * v$dsol[, j.5]
X		return(ranks = 2 * r - 1, A2)
X	}
X	else stop("invalid score function")
}
"rrs.test"<-
function(x0, x1, y, v, score = "wilcoxon")
{
X	if(missing(v) || is.null(v$dsol))
X		v <- rq(x0, y, dual = T)
X	r <- ranks(v, score)
X	x1hat <- as.matrix(qr.resid(qr(cbind(1, x0)), x1))
X	sn <- as.matrix(t(x1hat) %*% r$ranks)
X	sn <- t(sn) %*% solve(crossprod(x1hat)) %*% sn/r$A2
X	return(sn, rank = r$ranks)
}
