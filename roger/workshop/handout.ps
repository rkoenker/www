/I{Coord SetPage 1 setlinecap 1 setlinejoin
	LineTypes{RastersPerPoint ScaleArray}forall
	/Helvetica findfont
	PointSize RastersPerPoint mul Cex mul scalefont setfont
	/Colors GColors def
}bd
/BWOp{
	bw{currentrgbcolor add add 2.9 gt{1}{0}ifelse setgray}if
	exec
	bw{CurSc Sc}if
}bd
/IBu{}def
