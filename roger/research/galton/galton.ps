			}{pop pop}ifelse
			Left 1 sub dup /Left exch def 0 le
			{/Left PerByte def}
			{/MaskMove MaskMove Bits add def}ifelse
		}for
		pop
	}for
	/Colors GColors def saveSc Sc
}bd
