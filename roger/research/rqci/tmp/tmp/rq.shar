XEXTRA_C_NAMES=
XEXTRA_F_NAMES=
X
X# This is a Makefile produced by the S-PLUS utility CHAPTER. It guides
X# compilation of C, Ratfor and Fortran source code, loading of the resulting
X# object code, and installation of functions and helpfiles.
X# 
X# Overview: 
X# ========
X# 
X# You will need to attend to a few 'make' macro settings at the top of this
X# file first.  See the Detailed Instructions below for these. Then, if you
X# want to compile and load the default set of C and Fortran routines, type
X# (1) 'make install' to install functions on .Data and thereby enable
X# building of the default list of compiled routine names, then (2) 'make
X# load' to compile the object code, build the set of names to load, and load
X# this object code.  Other, secondary, 'make' targets are 'install.funs' and
X# 'install.help' ('install' makes both of those), 'clean' (remove only
X# intermediate object code) and 'virgin' (remove object code, the local
X# standalone S-PLUS executable if you built it, and the directory
X# .Data).
X# 
X# Detailed Instructions:
X# =====================
X# 
X# 1. On the line near the top that starts with "SHOME=", change the
X# directory pathname on the right of the equals sign to the pathname of the
X# top S-PLUS directory on your machine; use Splus SHOME to get this
X# pathname.
X# 
X# 2. Near the top, the macro WHICH_LOAD specifies whether 'make' targets
X# 'load' and 'all' should make a standalone S-PLUS binary executable named
X# "local.Sqpe" which includes the local C and Fortran code, or a
X# dyn.loadable file "rq_l.o" containing only this local code.  To
X# make a complete standalone executable, WHICH_LOAD should be set to
X# "static.load"; the only other possible value is "dyn.load".  Make sure a
X# comment symbol (#) appears in front of the setting you DON'T want.
X# The default has been set to "static.load".
X# 
X# Incidentally, you can always make targets 'static.load' or 'dyn.load'
X# regardless of the value of WHICH_LOAD. The macro just specifies what the
X# generic targets 'load' and 'all' should make.
X# 
X# 3. Near the top, the macro EXTRA_OBJ_FILES names object files (ending in
X# ".o") which should be loaded in addition to those which are part of this
X# chapter.  Add any additional object file names you want to load, separated
X# by spaces, on the right hand side of the equals sign.  There MUST be
X# corresponding C (".c"), Ratfor (".r") or Fortran (".f") files present in
X# this directory.
X# 
X# If you add file names to EXTRA_OBJ_FILES, you must also add the names of
X# the corresponding C functions or Fortran subroutines to the macros
X# EXTRA_C_NAMES and EXTRA_F_NAMES respectively, underneath EXTRA_OBJ_FILES.
X# The names added should be as they appear at the source-code level; do not
X# add leading or trailing underscores unless these are present in the
X# source-level name.
X# 
X# You won't generally need to change any more 'make' macros, or indeed
X# anything else in this Makefile.
X# 
X# 4. The file rq_i.c is a C language source file which will ensure
X# that the make target 'load' will load C and Fortran routines referenced
X# only through .C or .Fortran calls in S functions. If rq_i.c does
X# not exist, it will be made during 'make load' based on the objects in
X# .Data. If rq_i.c exists already and you have since added new C
X# or Fortran routine names to EXTRA_C_NAMES and EXTRA_F_NAMES, you must
X# remove rq_i.c so that it will get remade using this new
X# information. Do this now.
X# 
X# 5. Type 'make install.funs' to create the S functions on .Data.  This
X# must precede 'make load' in Step 6. (You can install the helpfiles at
X# this point as well by typing making 'install' instead of 'install.funs'.)
X# 
X# 6. Type 'make load'. This will build the list of routines to load, then
X# compile the C, Ratfor and Fortran source files specified by this Makefile,
X# and lastly load the routines named on the list into either a standalone
X# S-PLUS executable or a dyn.loadable file.
X# 
X# 7. To remove unnecessary object files, type 'make clean'. This will not
X# remove the dyn.loadable file rq_l.o or the standalone local.Sqpe.
X# To clean out everything including .Data and start over, use 'make
X# virgin'.
X# 
X# 8. See the helpfile for the "library" function in S-PLUS for hints on
X# how to install the new code as a library section.
X
X
X# ========================= End instructions. =============================
X
Xdefault : all
Xinclude $(SHOME)/newfun/lib/S_makefile
Xchapters=../rq
XSRC= rq.r
XOBJ= rq.o $(EXTRA_OBJ_FILES)
XCFLAGS=-O2
XFFLAGS=-O2
XFUNS=force_ld.q rq.s
XHELPS= ranks.d rrs.test.d rq.d trq.d qrq.d trq.print.d
XFLAGS=
XRM=-rm
X
Xall load: $(WHICH_LOAD)
X
Xstatic.load: rq.a
X	Splus LOAD $(FLAGS) CHAPTERS='"$(chapters)"'
X
Xdyn.load rq_l.o: rq.a
X	ld -r -o rq_l.o rq_i.o rq.a $(FLAGS)
X	@echo dynamically loadable file in rq_l.o
X
Xrq.a: rq_i.o $(OBJ) 
X	Splus LIBRARY rq.a rq_i.o $(OBJ)
X
Xrq_i.c:
X	-mkdir .Data
X	Splus make.init rq .Data
X
Xinstall : install.funs install.help
X
Xfuns install.funs : $(FUNS) .Data
X	Splus QINSTALL .Data $(FUNS)
X
Xforce_ld.q :
X	( echo "force.loading <- function(){" ;\
X	set $(EXTRA_C_NAMES) terminator ;\
X	while test $$1 != terminator ;\
X	do \
X		echo $$1 | sed 's:.*:.C("&"):' ;\
X		shift ;\
X	done ;\
X	set $(EXTRA_F_NAMES) terminator ;\
X	while test $$1 != terminator ;\
X	do \
X		echo $$1 | sed 's:.*:.Fortran("&"):' ;\
X		shift ;\
X	done ;\
X	echo } \
X	) > $@
X
X
X# force_ld.q :
X# 	echo "force.loading <- function(){ X\
X# 		stop(\"should not be executed\") X\
X# 		# Add .C and .Fortran calls here to force routines to  X\
X# 		# be loaded. For example, .C(\"fun1\"), .Fortran(\"fun2\"). X\
X# 	}" | tr X \\012  > $@
X
Xhelp install.help : $(HELPS) .Data/.Help
X	Splus HINSTALL .Data/.Help $(HELPS)
X	Splus help.findsum .Data
X
X.Data :
X	-mkdir $@
X.Data/.Help : .Data
X	-mkdir $@
X
Xvirgin : clean virgin.std
X# add additional cleanup rules/targets above here for target 'virgin'
Xclean :
X	$(RM) -f $(OBJ) rq_i.o S_load_time.[oc] core
Xvirgin.std :
X	$(RM) -rf .Data
X	$(RM) -f rq.a local.Sqpe rq_l.o rq_i.c force_ld.q
