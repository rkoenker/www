/W{grestore end}bd
% parameter setting commands
/saveAt{Attr begin
	/Atlinewidth currentlinewidth def
	/Atfont currentfont def
	/Atdash currentdash 2 array astore def
	/AtSc CurSc def
end}bd
/restAt{Attr begin
	Atlinewidth Atfont Atdash AtSc
	end
	SC aload pop setdash setfont setlinewidth
}bd
