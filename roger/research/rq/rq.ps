/Sc {
    dup dup 1 lt exch 0 ge and
    {1 exch sub setgray}  % explicit gray level [0,1)
    {1 sub Colors dup 3 1 roll length Rem floor get
     dup type /arraytype eq {aload pop setrgbcolor} {setgray} ifelse
    } ifelse
} bd
