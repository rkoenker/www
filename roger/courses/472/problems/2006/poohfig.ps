} def
/B {(\267)} def % bullet symbol 
/Stext
  { /pos exch def
    /srot exch def
    /cex exch def
    /ypos exch def
    /xpos exch def
    /str exch def
    
    xpos ypos moveto
    oldcex cex ne
      { currentfont cex oldcex div scalefont setfont
        /coffset  coffset cex oldcex div mul store
        /oldcex cex store
      } if
    gsave
	srot rotate
	str stringwidth pop neg
	pos 0.5 eq
	    { 2 div }
	    { pos 0.5 lt
	        { pop 0 }
	      if }
	ifelse
	coffset neg rmoveto
	str show
    grestore
  } store
/Schar
  { /cex exch def
    /str exch def
    oldcex cex ne
      { currentfont cex oldcex div scalefont setfont
        /coffset  coffset cex oldcex div mul store
        /oldcex cex store
      } if
    str stringwidth pop neg 2 div coffset neg rmoveto
    str show
  }  store
/concatprocs
    { /proc2 exch cvlit def
      /proc1 exch cvlit def
      /newproc proc1 length proc2 length add array def
      newproc 0 proc1 putinterval
      newproc proc1 length proc2 putinterval
      newproc cvx
    } def
