/h {rlineto} def
/j {neg rlineto} def
/k {exch neg exch rlineto} def
/l {neg exch neg exch rlineto} def
/S {setgray} def
/C {closepath} def
/N {newpath} def
/F {fill} def
/R { % filled rectangle
	/col exch def
	/bottom exch def
