	/LineTypes [ % in default units
		[] [1 2] [4 4] [8 4] [13 3] [16 2 2 2] [8 2 2 2] [1 13] [6 5] [12 4]
	] def
	/Attr 5 dict def/CurSc 1 def/Penup false def/XEQ{}def
}bd
