	/saveSc CurSc def /Colors IColors def
	/curstr Wid PerByte add 1 sub PerByte idiv string def
	/MaskByte 16#ff Bits 8 sub bitshift def
	1 1 Ht{
		currentfile curstr readhexstring pop pop
		/CurPos 0 def
