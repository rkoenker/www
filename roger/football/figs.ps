	Atlinewidth Atfont Atdash AtSc
	end
	SC aload pop setdash setfont setlinewidth
}bd
/SC{dup dup 0 eq
	{pop BackIdx
		{BackCol dup 0 lt {pop 1 setgray} {Sc}ifelse}
		{/Colors BColor def 1 Sc}ifelse}
	{/Colors GColors def Sc}ifelse
	/CurSc exch def
}bd
