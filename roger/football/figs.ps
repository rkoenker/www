/SimpleShow{0 Text-y 2 div neg rmoveto Show}bd
/FancyShow{
	/RotDiff exch def
	/Cos RotDiff cos abs def
	/Sin RotDiff sin abs def
	{
		( ) dup 0 4 -1 roll put
		dup stringwidth pop /CharWidth exch def
		Cos 0 eq{
			Text-y Sin div
		}{
