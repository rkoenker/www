150 dict begin gsave
/bd{bind def}def
/PVer 3200 def
% drawing commands
/I{Coord SetPage 1 setlinecap 1 setlinejoin
	LineTypes{RastersPerPoint ScaleArray}forall
	/Helvetica findfont
