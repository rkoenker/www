				CharWidth Cos div dup
				4 1 roll lt{exch pop}{pop}ifelse
			}ifelse
		}ifelse 2 div /CharDist exch def
		CharDist 0 translate 0 0 moveto
		gsave
			RotDiff rotate
			CharWidth 2 div neg Text-y 2 div neg rmoveto
			Show
		grestore
		CharDist 0 translate 0 0 moveto
	}forall
}bd
